# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./data/claw.db
DATA_DIR=./data

# Claude SDK Configuration
CLAUDE_BASE_URL=http://127.0.0.1:3456
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TURNS=100
CLAUDE_MAX_BUDGET_USD=10
CLAUDE_SANDBOX_ENABLED=false
CLAUDE_BASE_DIR=./data/sessions
# CLAUDE_TEMPLATE_DIR=./templates

# Session Management
MAX_SESSIONS_PER_USER=10
MAX_IDLE_MS=30

# Security
JWT_SECRET=change-this-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# IM Integrations (Optional)
# Feishu
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=

# Telegram
# TELEGRAM_BOT_TOKEN=

# QQ
# QQ_APP_ID=
# QQ_SECRET=

# DingTalk
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=

# WeChat
# WECHAT_APP_ID=
# WECHAT_SECRET=
# WECHAT_TOKEN=
# WECHAT_ENCODING_AES_KEY=
